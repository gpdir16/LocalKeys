{
    "name": "localkeys",
    "version": "1.5.0",
    "description": "Electron desktop app to encrypt and manage secrets locally with GUI + CLI approval prompts.",
    "author": "gpdir16 <me@gpdir16.com>",
    "homepage": "https://localkeys.privatestater.com",
    "bugs": {
        "url": "https://github.com/jaeone22/LocalKeys/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jaeone22/LocalKeys.git"
    },
    "main": "src/main.js",
    "bin": {
        "localkeys": "./cli/localkeys.js"
    },
    "scripts": {
        "start": "electron .",
        "build": "npm run build:mac && npm run build:win",
        "build:mac": "electron-builder --mac",
        "build:win": "electron-builder --win",
        "build:linux": "electron-builder --linux"
    },
    "devDependencies": {
        "electron": "^39.1.1",
        "electron-builder": "^26.8.1"
    },
    "overrides": {
        "config-file-ts": {
            "glob": "^10.5.0"
        },
        "js-yaml": "^4.1.1",
        "minimatch": "^10.2.1"
    },
    "build": {
        "appId": "com.localkeys.app",
        "productName": "LocalKeys",
        "directories": {
            "output": "dist"
        },
        "files": [
            "src/**/*",
            "cli/**/*"
        ],
        "asarUnpack": [
            "**/node_modules/electron-context-menu/**",
            "**/node_modules/electron-dl/**",
            "**/node_modules/ext-name/**"
        ],
        "mac": {
            "category": "public.app-category.developer-tools",
            "icon": "src/assets/macicon.png",
            "identity": null
        },
        "dmg": {
            "artifactName": "${productName}-macOS-${version}.${ext}"
        },
        "win": {
            "target": "nsis",
            "icon": "src/assets/icon.png"
        },
        "nsis": {
            "artifactName": "${productName}-Windows-${version}.${ext}"
        },
        "linux": {
            "target": "AppImage",
            "icon": "src/assets/icon.png"
        },
        "afterPack": "./scripts/sign-adhoc.js"
    },
    "dependencies": {
        "electron-context-menu": "^4.1.1",
        "electron-window-state": "^5.0.3"
    }
}
